# Clawd Soul — AI Provider Configuration
# Copy this file to .env and fill in your keys

# === Primary Provider (choose one) ===
# Options: azure-openai, openai, gemini, claude
AI_PROVIDER=azure-openai

# === Azure OpenAI ===
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Deployments (see your Azure portal)
AZURE_OPENAI_DEPLOYMENT_OBSERVE=gpt-5.4-nano-standard
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-5.4-mini-standard
AZURE_OPENAI_DEPLOYMENT_REASON=gpt-5.4-standard

# === OpenAI (official) ===
OPENAI_API_KEY=
OPENAI_MODEL_OBSERVE=gpt-4o-mini
OPENAI_MODEL_CHAT=gpt-4o-mini

# === Google Gemini ===
GEMINI_API_KEY=
GEMINI_MODEL_OBSERVE=gemini-2.0-flash
GEMINI_MODEL_CHAT=gemini-2.0-flash

# === Anthropic Claude ===
CLAUDE_API_KEY=
CLAUDE_MODEL_OBSERVE=claude-sonnet-4-5-20250514
CLAUDE_MODEL_CHAT=claude-sonnet-4-5-20250514

# === Embeddings (always Gemini — cheap & good) ===
GEMINI_EMBEDDING_KEY=
# Falls back to GEMINI_API_KEY if not set
